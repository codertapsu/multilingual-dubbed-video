<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!--
    Hardened-runtime exceptions VideoDubber needs because it bundles a Node
    single-executable orchestrator (V8 JIT) and a standalone CPython + native
    Python extensions (numpy / onnxruntime / ctranslate2 / llama.cpp, etc.).
    Required for the app to RUN under the hardened runtime that notarization
    mandates; see docs/APPLE_SIGNING.md.
  -->

  <!-- V8 / Python ctypes/ffi allocate executable memory (JIT). -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- CPython + ctypes map writable+executable memory; without this the process
       is killed with CODESIGNING on launch. -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Load-bearing here: the bundled Python dlopen()s many third-party .so/.dylib
       that do NOT share our Team ID. Library Validation would block them
       ("library load disallowed by system policy"); disabling it lets them load. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
