# =============================================================================
# VideoDubber environment configuration (example)
# =============================================================================
# Copy this file to ".env" and adjust as needed:
#     cp .env.example .env
#
# VideoDubber is LOCAL / OFFLINE-FIRST by default. Every value below has a
# sensible default and the app runs fully offline without any cloud keys.
# The cloud provider keys at the bottom are 100% OPTIONAL and are only used
# by the (future / optional) "cloud-enhanced" processing mode.
# =============================================================================

# -----------------------------------------------------------------------------
# Service URLs / ports
# -----------------------------------------------------------------------------
# Node orchestrator HTTP engine.
ORCHESTRATOR_URL=http://127.0.0.1:5100
# Python STT worker (FastAPI + faster-whisper).
STT_WORKER_URL=http://127.0.0.1:5101
# Python translation worker (FastAPI + Argos Translate).
TRANSLATION_WORKER_URL=http://127.0.0.1:5102
# Python TTS worker (FastAPI + Piper / system / fallback).
TTS_WORKER_URL=http://127.0.0.1:5103
# Angular UI dev-server port (scripts/dev.sh / pnpm dev:desktop).
ANGULAR_PORT=1420

# -----------------------------------------------------------------------------
# Desktop app service management (Tauri shell)
# -----------------------------------------------------------------------------
# The desktop app (pnpm app) auto-starts the backend on launch and stops it on
# quit. Set to 0/false to disable (e.g. when you run `pnpm dev` yourself).
VIDEODUBBER_MANAGE_SERVICES=1
# Project root the shell uses to find scripts/. Auto-detected from
# pnpm-workspace.yaml if left blank; set it if you launch the app from elsewhere.
VIDEODUBBER_REPO_DIR=

# -----------------------------------------------------------------------------
# Storage
# -----------------------------------------------------------------------------
# Where per-project workspaces are created. Default resolves to
# ~/VideoDubber/projects when unset. Each project gets its own subfolder.
VIDEODUBBER_PROJECTS_DIR=

# -----------------------------------------------------------------------------
# External binaries (leave blank to auto-discover on PATH)
# -----------------------------------------------------------------------------
# Absolute path to the ffmpeg binary. Falls back to PATH lookup if empty.
FFMPEG_PATH=
# Absolute path to the ffprobe binary. Falls back to PATH lookup if empty.
FFPROBE_PATH=
# Absolute path to the Python interpreter used to launch the workers.
# Falls back to PATH lookup (python3 / python) if empty.
PYTHON_PATH=

# -----------------------------------------------------------------------------
# Speech-to-text (faster-whisper)
# -----------------------------------------------------------------------------
# Whisper model size: tiny | base | small | medium | large-v3 (default: small).
# Larger models are more accurate but slower and need more RAM/VRAM.
FASTER_WHISPER_MODEL=small

# -----------------------------------------------------------------------------
# Text-to-speech (Piper — preferred local engine)
# -----------------------------------------------------------------------------
# Absolute path to the Piper executable. If empty, the TTS worker falls back
# to the system TTS (macOS "say" / espeak-ng) and finally a dev silent/sine
# WAV generator so the rest of the pipeline still works.
PIPER_BINARY_PATH=
# Absolute path to a Piper voice model (.onnx). Required to use Piper.
PIPER_VOICE_MODEL_PATH=

# =============================================================================
# OPTIONAL cloud provider keys (cloud-enhanced mode only)
# -----------------------------------------------------------------------------
# DO NOT set these unless you intentionally enable cloud providers. They are
# NOT required for normal, fully-offline operation. Never commit real keys.
# =============================================================================

# OpenAI (optional STT / translation / TTS).
OPENAI_API_KEY=
# DeepL (optional translation).
DEEPL_API_KEY=
# Google Cloud service account JSON path (optional STT / translation / TTS).
GOOGLE_APPLICATION_CREDENTIALS=
# Azure Speech (optional STT / TTS).
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=
# ElevenLabs (optional TTS).
ELEVENLABS_API_KEY=
