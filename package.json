{
  "name": "videodubber",
  "version": "0.3.0",
  "private": true,
  "description": "VideoDubber — a local/offline-first desktop app that dubs videos into another language.",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "bash scripts/dev.sh",
    "start": "bash scripts/start.sh",
    "stop": "bash scripts/stop.sh",
    "services": "bash scripts/start-services.sh",
    "app": "pnpm --filter videodubber-desktop tauri dev",
    "app:build": "pnpm --filter videodubber-desktop tauri build",
    "desktop:rebuild": "node scripts/clean-build.mjs",
    "package:sidecars": "bash scripts/package/build-sidecars.sh",
    "dev:desktop": "pnpm --filter videodubber-desktop dev",
    "dev:orchestrator": "pnpm --filter @videodubber/node-orchestrator dev",
    "dev:workers": "bash scripts/dev-workers.sh",
    "build": "pnpm -r --filter \"./packages/**\" --filter \"./workers/media-worker\" build",
    "lint": "eslint .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "verify": "tsx scripts/verify-environment.ts",
    "eval:translation": "tsx scripts/eval-translation.ts",
    "dmg:instructions": "bash scripts/package/dmg-add-instructions.sh"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "26.0.1",
    "@typescript-eslint/eslint-plugin": "8.62.0",
    "@typescript-eslint/parser": "8.62.0",
    "esbuild": "0.28.1",
    "eslint": "10.5.0",
    "postject": "1.0.0-alpha.6",
    "prettier": "3.8.4",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.0",
    "vitest": "4.1.9"
  }
}
