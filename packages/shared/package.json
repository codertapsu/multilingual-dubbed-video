{
  "name": "@videodubber/shared",
  "version": "0.1.0",
  "description": "Shared TypeScript types and utilities (subtitles, language, pipeline, errors) for VideoDubber.",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "26.0.1",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  }
}
